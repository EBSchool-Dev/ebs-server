echo "Running pre-push checks..."

echo "→ Type checking..."
npx tsc --noEmit
if [ $? -ne 0 ]; then
  echo "✖ TypeScript errors found. Fix them before pushing."
  exit 1
fi

echo "→ Running unit tests..."
npm test -- --passWithNoTests
if [ $? -ne 0 ]; then
  echo "✖ Tests failed. Fix them before pushing."
  exit 1
fi

echo "✔ All pre-push checks passed."
